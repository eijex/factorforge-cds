{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factorforge.eijex.com/schemas/design_package.schema.json",
  "title": "FactorForge Open Bio Design Package",
  "description": "Public, in-silico-only CDS design output contract. Raw sequences are intentionally excluded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "design_package_version",
    "design_id",
    "sequence_type",
    "input_type",
    "host_profile",
    "optimization",
    "metrics",
    "validation",
    "evidence",
    "claim_boundary"
  ],
  "properties": {
    "design_package_version": {
      "type": "string",
      "const": "1.0"
    },
    "design_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence_type": {
      "type": "string",
      "enum": ["cds"]
    },
    "input_type": {
      "type": "string",
      "enum": ["protein", "cds"]
    },
    "host_profile": {
      "$ref": "#/$defs/hostProfile"
    },
    "optimization": {
      "$ref": "#/$defs/optimization"
    },
    "metrics": {
      "$ref": "#/$defs/metrics"
    },
    "validation": {
      "$ref": "#/$defs/validation"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "claim_boundary": {
      "$ref": "#/$defs/claimBoundary"
    },
    "protein_risk": {
      "$ref": "#/$defs/proteinRisk"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "validation": {
            "properties": {
              "biological_pass": {
                "const": true
              }
            },
            "required": ["biological_pass"]
          }
        }
      },
      "then": {
        "properties": {
          "validation": {
            "properties": {
              "aa_identity": {
                "const": 1.0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation": {
            "properties": {
              "assembly_pass": {
                "const": true
              }
            },
            "required": ["assembly_pass"]
          }
        }
      },
      "then": {
        "properties": {
          "validation": {
            "properties": {
              "forbidden_type_iis_site_count": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metrics": {
            "properties": {
              "mfe_status": {
                "enum": ["not_computed", "unavailable", "failed"]
              }
            },
            "required": ["mfe_status"]
          }
        }
      },
      "then": {
        "properties": {
          "metrics": {
            "properties": {
              "mfe_kcal_mol": {
                "type": "null"
              },
              "mfe_used": {
                "const": false
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "proteinRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tm_count",
        "mean_kd_score",
        "signal_peptide_predicted",
        "risk_level",
        "warnings"
      ],
      "properties": {
        "tm_count": {
          "type": "integer",
          "minimum": 0
        },
        "mean_kd_score": {
          "type": "number"
        },
        "signal_peptide_predicted": {
          "type": "boolean"
        },
        "risk_level": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hostProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "scientific_name",
        "ncbi_taxonomy_id",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["nbenthamiana", "by2"]
        },
        "display_name": {
          "type": "string"
        },
        "scientific_name": {
          "type": "string"
        },
        "ncbi_taxonomy_id": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["stable", "experimental", "draft", "future"]
        }
      },
      "oneOf": [
        {
          "properties": {
            "id": {
              "const": "nbenthamiana"
            },
            "display_name": {
              "const": "N. benthamiana"
            },
            "scientific_name": {
              "const": "Nicotiana benthamiana"
            },
            "ncbi_taxonomy_id": {
              "const": 4100
            },
            "status": {
              "const": "stable"
            }
          }
        },
        {
          "properties": {
            "id": {
              "const": "by2"
            },
            "display_name": {
              "const": "BY-2 / N. tabacum"
            },
            "scientific_name": {
              "const": "Nicotiana tabacum"
            },
            "ncbi_taxonomy_id": {
              "const": 4097
            },
            "status": {
              "const": "experimental"
            }
          }
        }
      ]
    },
    "optimization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "profile"],
      "properties": {
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cai",
        "gc_percent",
        "mfe_kcal_mol",
        "mfe_status",
        "mfe_used"
      ],
      "properties": {
        "cai": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "gc_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "mfe_kcal_mol": {
          "oneOf": [
            {
              "type": "number",
              "not": {
                "const": 0.0
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "mfe_status": {
          "type": "string",
          "enum": ["computed", "not_computed", "unavailable", "failed"]
        },
        "mfe_used": {
          "type": "boolean"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "biological_pass",
        "assembly_pass",
        "aa_identity",
        "forbidden_type_iis_site_count"
      ],
      "properties": {
        "biological_pass": {
          "type": "boolean"
        },
        "assembly_pass": {
          "type": "boolean"
        },
        "aa_identity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "forbidden_type_iis_site_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence_hash", "registry_version", "registry_hash"],
      "properties": {
        "sequence_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "registry_version": {
          "type": "string",
          "minLength": 1
        },
        "registry_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "claimBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_silico_only",
        "no_yield_claim",
        "no_wet_lab_claim",
        "no_clinical_claim"
      ],
      "properties": {
        "in_silico_only": {
          "const": true
        },
        "no_yield_claim": {
          "const": true
        },
        "no_wet_lab_claim": {
          "const": true
        },
        "no_clinical_claim": {
          "const": true
        }
      }
    }
  }
}
